<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Movie Search Engine</title>

  <style>

    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      font-family: Arial, sans-serif;
    }

    body{
      background:#121212;
      color:white;
      min-height:100vh;
      padding:30px;
    }

    h1{
      text-align:center;
      margin-bottom:25px;
      font-size:40px;
      color:#ffcc00;
    }

    .search-box{
      width:100%;
      max-width:600px;
      margin:auto;
      display:flex;
      gap:10px;
      margin-bottom:40px;
    }

    .search-box input{
      flex:1;
      padding:15px;
      border:none;
      border-radius:10px;
      font-size:16px;
      outline:none;
    }

    .search-box button{
      padding:15px 25px;
      border:none;
      border-radius:10px;
      background:#ffcc00;
      color:black;
      font-weight:bold;
      cursor:pointer;
      transition:0.3s;
    }

    .search-box button:hover{
      background:#ffdb4d;
    }

    .movies{
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
      gap:25px;
    }

    .movie-card{
      background:#1e1e1e;
      border-radius:15px;
      overflow:hidden;
      transition:0.3s;
      box-shadow:0 5px 15px rgba(0,0,0,0.5);
    }

    .movie-card:hover{
      transform:translateY(-5px);
    }

    .movie-card img{
      width:100%;
      height:320px;
      object-fit:cover;
    }

    .movie-info{
      padding:15px;
    }

    .movie-info h2{
      font-size:20px;
      margin-bottom:10px;
      color:#ffcc00;
    }

    .movie-info p{
      margin:5px 0;
      color:#ddd;
      font-size:15px;
    }

    .error{
      text-align:center;
      margin-top:20px;
      color:red;
      font-size:18px;
    }

  </style>
</head>

<body>

  <h1>Movie Search Engine</h1>

  <div class="search-box">
    <input type="text" id="movieInput" placeholder="Enter movie name">
    <button onclick="searchMovie()">Search</button>
  </div>

  <div class="movies" id="moviesContainer"></div>

  <div class="error" id="error"></div>

  <script>

    const apiKey = "YOUR_API_KEY";

    async function searchMovie(){

      const movieName =
        document.getElementById("movieInput").value;

      const moviesContainer =
        document.getElementById("moviesContainer");

      const error =
        document.getElementById("error");

      moviesContainer.innerHTML = "";
      error.innerHTML = "";

      if(movieName === ""){
        error.innerHTML = "Please enter a movie name!";
        return;
      }

      const apiURL =
      `https://www.omdbapi.com/?s=${movieName}&apikey=${apiKey}`;

      const response = await fetch(apiURL);

      const data = await response.json();

      if(data.Response === "False"){
        error.innerHTML = "Movie not found!";
        return;
      }

      data.Search.forEach(movie => {

        const poster =
          movie.Poster !== "N/A"
          ? movie.Poster
          : "https://via.placeholder.com/300x400?text=No+Image";

        const movieCard = `
          <div class="movie-card">

            <img src="${poster}" alt="${movie.Title}">

            <div class="movie-info">
              <h2>${movie.Title}</h2>

              <p><strong>Year:</strong> ${movie.Year}</p>

              <p><strong>Type:</strong> ${movie.Type}</p>

              <p><strong>IMDb ID:</strong> ${movie.imdbID}</p>
            </div>

          </div>
        `;

        moviesContainer.innerHTML += movieCard;
      });

    }

  </script>

</body>
</html>
